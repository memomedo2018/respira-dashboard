RewriteEngine On

# Redirect /index.html and nested */index.html to clean directory URLs.
RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html[\s?] [NC]
RewriteRule ^(.*/)?index\.html$ /$1 [R=301,L]

# Proxy /api/store to Railway live API so store page always gets fresh data
RewriteRule ^api/store$ https://perfect-art-production.up.railway.app/api/store [R=302,L]

# Disable LiteSpeed server-side cache for all files
<IfModule LiteSpeed>
    CacheDisable public /
</IfModule>

# No caching for HTML pages
<FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
    Header set X-LiteSpeed-Cache-Control "no-cache"
</FilesMatch>

# No caching for JSON data files
<FilesMatch "\.(json)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
    Header set X-LiteSpeed-Cache-Control "no-cache"
</FilesMatch>

# Disable compression for JSON so FTP uploads take effect immediately
<IfModule mod_deflate.c>
    SetEnvIfNoCase Request_URI \.json$ no-gzip dont-vary
</IfModule>
<IfModule mod_brotli.c>
    SetEnvIfNoCase Request_URI \.json$ no-brotli dont-vary
</IfModule>
